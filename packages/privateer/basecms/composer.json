{
    "name": "privateer/basecms",
    "description": "Shared CMS package for posts, pages, categories, assets, and visits.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/ai": "^0.4.2",
        "filament/filament": "^5.0",
        "jaybizzle/crawler-detect": "^1.3",
        "laravel/framework": "^13.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-feed": "^4.4",
        "spatie/laravel-markdown": "^2.7",
        "spatie/laravel-sitemap": "^7.3",
        "spatie/laravel-sluggable": "^3.7",
        "symfony/yaml": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "Privateer\\Basecms\\": "src/",
            "Privateer\\Basecms\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Privateer\\Basecms\\Providers\\BasecmsServiceProvider",
                "Privateer\\Basecms\\Providers\\Filament\\BasecmsPanelProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
